# =============================================
# TrackFlow Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git.

# --- Database ---
# Local development: file:./dev.db
# Production (Render PostgreSQL): postgresql://user:password@host/dbname
DATABASE_URL="file:./dev.db"

# --- Server ---
PORT=5000

# --- Authentication ---
# Use a long, random string. Generate one at: https://randomkeygen.com
JWT_SECRET="your_super_secret_jwt_key_here"

# --- TCS Courier API ---
TCS_USERNAME="your_tcs_username"
TCS_PASSWORD="your_tcs_password"
TCS_BEARER_TOKEN="your_tcs_bearer_token"

# --- Email Alerts (SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_gmail_app_password"
VENDOR_EMAIL="alerts_recipient@gmail.com"

# --- CORS (Production only) ---
# Set this to your Vercel frontend URL after deployment
FRONTEND_URL="https://your-app.vercel.app"

# --- WhatsApp Cloud API (Optional) ---
WHATSAPP_TOKEN="your_meta_whatsapp_token"
PHONE_NUMBER_ID="your_phone_number_id"

# --- PostEx API (Optional) ---
POSTEX_TOKEN="your_postex_token"
